{
    "openapi": "3.0.0",
    "info": {
        "title": "XeGhépTuyến API (DATN_WD50)",
        "description": "Hệ thống API quản lý và đặt xe ghép tuyến XeGhépTuyến",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Local Development API Server"
        }
    ],
    "paths": {
        "/api/admin/audit-logs": {
            "get": {
                "tags": [
                    "Admin Audit Logs"
                ],
                "summary": "Lấy danh sách nhật ký hoạt động (Audit Logs)",
                "operationId": "a2155c63b852ee3e6d726dd31c7cbf41",
                "parameters": [
                    {
                        "name": "user_id",
                        "in": "query",
                        "description": "Lọc theo ID người thực hiện",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    },
                    {
                        "name": "action",
                        "in": "query",
                        "description": "Lọc theo loại hành động",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "date_from",
                        "in": "query",
                        "description": "Từ ngày (YYYY-MM-DD)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "date_to",
                        "in": "query",
                        "description": "Đến ngày (YYYY-MM-DD)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Tìm kiếm từ khóa",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Danh sách nhật ký hoạt động",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Chưa xác thực"
                    },
                    "403": {
                        "description": "Không có quyền truy cập"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/customer/auth/send-otp": {
            "post": {
                "tags": [
                    "Customer Auth"
                ],
                "summary": "Gửi OTP xác thực số điện thoại",
                "operationId": "e2041bcee6cc25e9457d7dd40ae1c9a7",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "phone"
                                ],
                                "properties": {
                                    "phone": {
                                        "description": "Số điện thoại Việt Nam",
                                        "type": "string",
                                        "example": "0900000000"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Gửi OTP thành công",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Mã OTP đã được gửi đến số điện thoại của bạn"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "429": {
                        "description": "Quá nhiều yêu cầu OTP",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Vui lòng đợi trước khi gửi lại OTP"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/customer/auth/login": {
            "post": {
                "tags": [
                    "Customer Auth"
                ],
                "summary": "Đăng nhập tài khoản khách hàng",
                "operationId": "d01f6eb59ff52454f1412a129c96c7ce",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "phone",
                                    "password"
                                ],
                                "properties": {
                                    "phone": {
                                        "type": "string",
                                        "example": "0900000000"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Đăng nhập thành công",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Đăng nhập thành công"
                                        },
                                        "data": {
                                            "properties": {
                                                "token": {
                                                    "type": "string",
                                                    "example": "1|AbcDeFg..."
                                                },
                                                "user": {
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Sai số điện thoại hoặc mật khẩu",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Số điện thoại hoặc mật khẩu không đúng"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/public/trips": {
            "get": {
                "tags": [
                    "Trips"
                ],
                "summary": "Tìm kiếm chuyến xe ghép",
                "operationId": "86bdae1d673c7c7ecb81d0e1e47c5fd3",
                "parameters": [
                    {
                        "name": "from_city",
                        "in": "query",
                        "description": "Thành phố xuất phát",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "to_city",
                        "in": "query",
                        "description": "Thành phố đến",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "date",
                        "in": "query",
                        "description": "Ngày đi (YYYY-MM-DD)",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "passengers",
                        "in": "query",
                        "description": "Số lượng hành khách (1-4)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "sort",
                        "in": "query",
                        "description": "Sắp xếp kết quả",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "price_asc",
                                "price_desc",
                                "depart_asc"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Danh sách chuyến xe hợp lệ",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Nhập token Sanctum của bạn",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Admin Audit Logs",
            "description": "Admin Audit Logs"
        },
        {
            "name": "Customer Auth",
            "description": "Customer Auth"
        },
        {
            "name": "Trips",
            "description": "Trips"
        }
    ]
}